# =============================================================================
# OBSS Platform - Environment Variables
# Telecom OSS/BSS Platform
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=obss
POSTGRES_USER=obss_admin
POSTGRES_PASSWORD=obss_s3cur3_p@ss
POSTGRES_SSL_MODE=Prefer
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=512MB

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=obss_r3d1s_p@ss
REDIS_DB=0
REDIS_CONNECTION_STRING=redis:6379,password=obss_r3d1s_p@ss,defaultDatabase=0

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=obss_admin
RABBITMQ_PASSWORD=obss_rmq_s3cur3
RABBITMQ_VHOST=/
RABBITMQ_CONNECTION_STRING=amqp://obss_admin:obss_rmq_s3cur3@rabbitmq:5672/

# ── MinIO ───────────────────────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=obss_admin
MINIO_ROOT_PASSWORD=obss_m1n10_s3cur3
MINIO_DEFAULT_BUCKETS=documents,exports,archives,templates

# ── OpenSearch ──────────────────────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Obss_0p3nS3@rch!
OPENSEARCH_ADMIN_USER=admin
OPENSEARCH_ADMIN_PASSWORD=Obss_0p3nS3@rch!
OPENSEARCH_INDEX_PREFIX=obss

# ── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_HTTPS_PORT=8443
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=obss_kc_s3cur3
KEYCLOAK_REALM=obss
KEYCLOAK_CLIENT_ID=obss-gateway
KEYCLOAK_CLIENT_SECRET=obss_kc_cl13nt_s3cr3t
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/obss_keycloak
KC_DB_USERNAME=obss_admin
KC_DB_PASSWORD=obss_s3cur3_p@ss

# ── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
PROMETHEUS_STORAGE_PATH=/prometheus

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=obss_gr4f_s3cur3

# ── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_COLLECTOR_HOST=otel-collector
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=obss-platform
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ── .NET Application Settings ──────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:8080
DOTNET_ENVIRONMENT=Development
DOTNET_RUNNING_IN_CONTAINER=true

# --- Backend CORS Dynamic Allocation ---
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:3001
Cors__AllowedOrigins__2=http://localhost:3080
Cors__AllowedOrigins__3=http://${HOST_IP}:3000
Cors__AllowedOrigins__4=http://${HOST_IP}:3001
Cors__AllowedOrigins__5=http://${HOST_IP}:3080

#--- Frontend (Set Dynamically at Runtime) -----
NEXT_PUBLIC_API_URL=http://${HOST_IP}:5020
NEXT_PUBLIC_KEYCLOAK_URL=http://${HOST_IP}:8080
NEXT_PUBLIC_KEYCLOAK_REALM=obss
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=obss-frontend

